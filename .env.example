# =============================================================================
#  Nakama Bordados — Plantilla de variables de entorno
#  Copia este archivo a .env.local y rellena los valores REALES.
#  NUNCA subas .env.local ni secretos reales al repositorio.
# =============================================================================

# --- Base de datos local (clon de la BD original de WordPress) ---
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=nakamabo_wp369

# --- Auth (OBLIGATORIO) ---
# Sin JWT_SECRET la app NO arranca (fail-closed). Genera uno fuerte, p. ej.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# --- WordPress ---
# Endpoint GraphQL público del sitio (se envía al navegador).
NEXT_PUBLIC_WP_GRAPHQL_URL=https://nakamabordados.com/graphql
# Destino del botón de administrador (escritorio de WordPress).
NEXT_PUBLIC_WP_ADMIN_URL=https://nakamabordados.com/wp-admin
# Base REST de WooCommerce/WordPress (webhooks, hero-config, etc.).
WP_REST_URL=https://nakamabordados.com

# URL pública del sitio (usada por el guard anti-abuso de /api/shipping y /api/tracking).
NEXT_PUBLIC_SITE_URL=https://nakamabordados.com

# --- Envia.com (paquetería) ---
# ¡ROTAR! Los valores previos quedaron expuestos en el historial de git.
ENVIA_API_TOKEN=
ENVIA_WEBHOOK_SECRET=

# --- WooCommerce REST (webhook de tracking) ---
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
