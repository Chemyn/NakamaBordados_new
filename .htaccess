# END NON_LSCACHE

# ----------------------------------------------------------------------
# NAKAMA - Next.js (Static Export) + WordPress (API Backend) Coexistence
# ----------------------------------------------------------------------

# 1. Priorizar index.html (Next.js) sobre index.php (WordPress) al acceder a la raíz
DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# 1.2 Redirigir URLs antiguas de WooCommerce (Campañas de marketing) hacia Next.js
#     QSA (Query String Append): Preserva parámetros de tracking como gclid, fbclid, utm_*, etc.
#     NC (No Case): Ignora mayúsculas/minúsculas.
#     R=301: Redirección permanente para conservar SEO y conversiones.
RewriteRule ^producto/([^/]+)/?$ /product/?slug=$1 [R=301,L,NC,QSA]
RewriteRule ^categoria-producto/([^/]+)/?$ /store/?category=$1 [R=301,L,NC,QSA]
RewriteRule ^tienda/?$ /store/ [R=301,L,NC,QSA]
RewriteRule ^carrito/?$ /cart/ [R=301,L,NC,QSA]

# 1.5 Redirigir a WordPress las consultas por query string en la raíz:
#   ?rest_route=  -> API REST (productos, hero, mantenimiento...)
#   ?nk_bridge=   -> bridge de carrito headless -> WooCommerce
#   ?wc-ajax=     -> AJAX del checkout de WooCommerce (sin esto,
#                    /finalizar-compra/ se queda cargando para siempre)
#   ?wc-api=      -> callbacks/webhooks de pasarelas de pago
# E=Cache-Control:no-cache evita que LiteSpeed cachee estas respuestas
# (respuestas vacías cacheadas dejaban categorías enteras sin productos).
RewriteCond %{QUERY_STRING} rest_route= [NC,OR]
RewriteCond %{QUERY_STRING} nk_bridge= [NC,OR]
RewriteCond %{QUERY_STRING} wc-ajax= [NC,OR]
RewriteCond %{QUERY_STRING} wc-api= [NC]
RewriteRule ^ index.php [E=Cache-Control:no-cache,L]

# 2. Rutas del núcleo de WordPress (archivos y directorios FÍSICOS): servir tal cual
RewriteCond %{REQUEST_URI} ^/wp-admin(/|$) [NC,OR]
RewriteCond %{REQUEST_URI} ^/wp-includes/ [NC,OR]
RewriteCond %{REQUEST_URI} ^/wp-content/ [NC,OR]
RewriteCond %{REQUEST_URI} ^/xmlrpc\.php$ [NC,OR]
RewriteCond %{REQUEST_URI} ^/wp-login\.php$ [NC]
RewriteRule ^ - [L]

# 2.5 APIs "bonitas" de WordPress: /wp-json y /graphql NO existen como archivos
# físicos; deben enrutar al front controller. Un pass-through aquí los deja en
# 404 y rompe el admin de WooCommerce (que consume /wp-json/): errores como
# "Ha ocurrido un error al cargar las diversas recomendaciones", fallos al
# cambiar estados de pedido, etc.
RewriteRule ^(wp-json|graphql)(/|$) index.php [E=Cache-Control:no-cache,L]

# 2.6 Enrutar el Checkout de WooCommerce directamente a WordPress (index.php) sin cachear
RewriteCond %{REQUEST_URI} ^/finalizar-compra(/|$) [NC]
RewriteRule ^ index.php [E=Cache-Control:no-cache,L]

# 3. Servir archivos físicos si existen (imágenes, scripts en _next/static, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 4. Enrutamiento de URLs Limpias de Next.js (ej. /store -> store.html)
# Si se consulta /ruta y existe el archivo físico ruta.html en el servidor, lo sirve ocultando la extensión .html
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^([^/]+)/?$ /$1.html [L]

# 5. Redirección de respaldo para páginas dinámicas o consultas no encontradas de WordPress
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>


# Wordfence WAF
<IfModule LiteSpeed>
php_value auto_prepend_file '/home/nakamabo/public_html/wordfence-waf.php'
</IfModule>
<IfModule lsapi_module>
php_value auto_prepend_file '/home/nakamabo/public_html/wordfence-waf.php'
</IfModule>
<Files ".user.ini">
<IfModule mod_authz_core.c>
	Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
	Order deny,allow
	Deny from all
</IfModule>
</Files>

# END Wordfence WAF

# Proteger el archivo .htaccess
<files .htaccess>
Order Allow,Deny
#Deny from all
</files>
# Proteger el archivo wp-config.php
<files wp-config.php>
Order Allow,Deny
Deny from all
</files>
# Proteger la navegación de carpetas
Options All -Indexes

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php82” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
